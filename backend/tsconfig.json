{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "module": "CommonJS",
    /* Updated from 'Node' to 'Node10' or 'NodeNext' to satisfy modern TS requirements */
    /* Or use 'ignoreDeprecations' if you must stay on old resolution, but 'Node' is safest here */
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    /* ADDED: Explicitly set the root directory to fix the TS5011 error on Render */
    "rootDir": "./src"
  },
  "include": ["src/**/*", "types/**/*"],
  "exclude": ["node_modules", "dist"]
}
